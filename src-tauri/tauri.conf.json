{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Clod Helper",
  "version": "0.1.0",
  "identifier": "ru.iimperium.clodhelper",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Clod Helper",
        "width": 960,
        "height": 680,
        "minWidth": 880,
        "minHeight": 620,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "backgroundColor": "#000000"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/*"
    ],
    "publisher": "iimperium",
    "copyright": "Copyright (c) 2026 iimperium",
    "category": "DeveloperTool",
    "shortDescription": "Установщик Claude Code и Claude Desktop через прокси",
    "longDescription": "Clod Helper — десктопная утилита для установки и настройки Claude Code (CLI) и Claude Desktop через купленный HTTP-прокси. Нужен в регионах где Anthropic API заблокирован напрямую.",
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installMode": "currentUser",
        "displayLanguageSelector": false,
        "languages": ["Russian"]
      }
    }
  }
}
